#!/usr/bin/env bash
set -euo pipefail

TASKS_DIR="$(cd "$(dirname "$0")" && pwd)"
SCHEMA_REQUIRED_FIELDS=("name" "description" "status" "type" "priority")
VALID_STATUS=("todo" "in-progress" "done" "blocked")
VALID_TYPE=("pokemon" "route" "trainer" "item" "mechanic" "chunk")
VALID_PRIORITY=("high" "medium" "low")

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

status_color() {
    case "$1" in
        todo)        echo "${YELLOW}" ;;
        in-progress) echo "${BLUE}" ;;
        done)        echo "${GREEN}" ;;
        blocked)     echo "${RED}" ;;
        *)           echo "${NC}" ;;
    esac
}

priority_icon() {
    case "$1" in
        high)   echo "!!!" ;;
        medium) echo "!! " ;;
        low)    echo "!  " ;;
        *)      echo "   " ;;
    esac
}

# Read a frontmatter field from a task file
read_field() {
    local file="$1" field="$2"
    sed -n '/^---$/,/^---$/p' "$file" | grep "^${field}:" | sed "s/^${field}:[[:space:]]*//" | sed 's/^"\(.*\)"$/\1/' | sed "s/^'\(.*\)'$/\1/"
}

# Get next available ID
next_id() {
    local max=0
    for f in "$TASKS_DIR"/[0-9][0-9][0-9].md; do
        [ -f "$f" ] || continue
        local num
        num=$(basename "$f" .md | sed 's/^0*//')
        [ -z "$num" ] && num=0
        [ "$num" -gt "$max" ] && max=$num
    done
    printf "%03d" $((max + 1))
}

# Validate a task file against schema
validate_file() {
    local file="$1"
    local errors=0

    # Check frontmatter exists
    if ! head -1 "$file" | grep -q '^---$'; then
        echo -e "${RED}ERROR:${NC} $file - Missing YAML frontmatter"
        return 1
    fi

    # Check required fields
    for field in "${SCHEMA_REQUIRED_FIELDS[@]}"; do
        local val
        val=$(read_field "$file" "$field")
        if [ -z "$val" ]; then
            echo -e "${RED}MISSING:${NC} $file - required field '${field}'"
            errors=$((errors + 1))
        fi
    done

    # Validate enum values
    local status
    status=$(read_field "$file" "status")
    if [ -n "$status" ]; then
        local valid=false
        for v in "${VALID_STATUS[@]}"; do [ "$v" = "$status" ] && valid=true; done
        if ! $valid; then
            echo -e "${RED}INVALID:${NC} $file - status '${status}' must be one of: ${VALID_STATUS[*]}"
            errors=$((errors + 1))
        fi
    fi

    local type
    type=$(read_field "$file" "type")
    if [ -n "$type" ]; then
        local valid=false
        for v in "${VALID_TYPE[@]}"; do [ "$v" = "$type" ] && valid=true; done
        if ! $valid; then
            echo -e "${RED}INVALID:${NC} $file - type '${type}' must be one of: ${VALID_TYPE[*]}"
            errors=$((errors + 1))
        fi
    fi

    local priority
    priority=$(read_field "$file" "priority")
    if [ -n "$priority" ]; then
        local valid=false
        for v in "${VALID_PRIORITY[@]}"; do [ "$v" = "$priority" ] && valid=true; done
        if ! $valid; then
            echo -e "${RED}INVALID:${NC} $file - priority '${priority}' must be one of: ${VALID_PRIORITY[*]}"
            errors=$((errors + 1))
        fi
    fi

    return $errors
}

# --- Commands ---

cmd_list() {
    local filter_status="" filter_type="" filter_chunk="" filter_pokemon=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --status)  filter_status="$2"; shift 2 ;;
            --type)    filter_type="$2"; shift 2 ;;
            --chunk)   filter_chunk="$2"; shift 2 ;;
            --pokemon) filter_pokemon="$2"; shift 2 ;;
            *)         shift ;;
        esac
    done

    local count=0
    printf "${BOLD}%-5s %-3s %-12s %-10s %-8s %-15s %s${NC}\n" "ID" "PRI" "STATUS" "TYPE" "CHUNK" "POKEMON" "NAME"
    printf "%-5s %-3s %-12s %-10s %-8s %-15s %s\n" "----" "---" "----------" "--------" "-------" "-----------" "--------------------"

    for f in "$TASKS_DIR"/[0-9][0-9][0-9].md; do
        [ -f "$f" ] || continue
        local id name status type priority pokemon chunk
        id=$(basename "$f" .md)
        name=$(read_field "$f" "name")
        status=$(read_field "$f" "status")
        type=$(read_field "$f" "type")
        priority=$(read_field "$f" "priority")
        pokemon=$(read_field "$f" "pokemon")
        chunk=$(read_field "$f" "chunk")

        # Apply filters
        [ -n "$filter_status" ] && [ "$status" != "$filter_status" ] && continue
        [ -n "$filter_type" ] && [ "$type" != "$filter_type" ] && continue
        [ -n "$filter_chunk" ] && [ "$chunk" != "$filter_chunk" ] && continue
        [ -n "$filter_pokemon" ] && ! echo "$pokemon" | grep -qi "$filter_pokemon" && continue

        local sc
        sc=$(status_color "$status")
        local pi
        pi=$(priority_icon "$priority")

        printf "%-5s ${CYAN}%s${NC} ${sc}%-12s${NC} %-10s %-8s %-15s %s\n" \
            "$id" "$pi" "$status" "$type" "${chunk:--}" "${pokemon:--}" "$name"
        count=$((count + 1))
    done

    echo ""
    echo -e "${DIM}${count} task(s)${NC}"
}

cmd_get() {
    local id="$1"
    local file="$TASKS_DIR/${id}.md"

    if [ ! -f "$file" ]; then
        echo -e "${RED}Task ${id} not found${NC}"
        exit 1
    fi

    cat "$file"
}

cmd_create() {
    local name="" description="" status="todo" type="pokemon" priority="medium" pokemon="" chunk="" tags=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --name)        name="$2"; shift 2 ;;
            --description) description="$2"; shift 2 ;;
            --status)      status="$2"; shift 2 ;;
            --type)        type="$2"; shift 2 ;;
            --priority)    priority="$2"; shift 2 ;;
            --pokemon)     pokemon="$2"; shift 2 ;;
            --chunk)       chunk="$2"; shift 2 ;;
            --tags)        tags="$2"; shift 2 ;;
            *)             shift ;;
        esac
    done

    if [ -z "$name" ]; then
        echo -e "${RED}--name is required${NC}"
        exit 1
    fi
    if [ -z "$description" ]; then
        echo -e "${RED}--description is required${NC}"
        exit 1
    fi

    local id
    id=$(next_id)
    local file="$TASKS_DIR/${id}.md"
    local today
    today=$(date +%Y-%m-%d)

    {
        echo "---"
        echo "name: \"${name}\""
        echo "description: \"${description}\""
        echo "status: ${status}"
        echo "type: ${type}"
        echo "priority: ${priority}"
        [ -n "$pokemon" ] && echo "pokemon: \"${pokemon}\""
        [ -n "$chunk" ] && echo "chunk: \"${chunk}\""
        [ -n "$tags" ] && echo "tags: [${tags}]"
        echo "created: ${today}"
        echo "updated: ${today}"
        echo "---"
        echo ""
        echo "# ${name}"
        echo ""
        echo "## Notes"
        echo ""
    } > "$file"

    echo -e "${GREEN}Created task ${id}:${NC} ${name}"
    echo -e "${DIM}${file}${NC}"
}

cmd_update() {
    local id="$1"; shift
    local file="$TASKS_DIR/${id}.md"

    if [ ! -f "$file" ]; then
        echo -e "${RED}Task ${id} not found${NC}"
        exit 1
    fi

    local today
    today=$(date +%Y-%m-%d)

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --status)
                sed -i '' "s/^status: .*/status: $2/" "$file"
                echo -e "Status → ${BOLD}$2${NC}"
                shift 2 ;;
            --priority)
                sed -i '' "s/^priority: .*/priority: $2/" "$file"
                echo -e "Priority → ${BOLD}$2${NC}"
                shift 2 ;;
            --chunk)
                if grep -q '^chunk:' "$file"; then
                    sed -i '' "s/^chunk: .*/chunk: \"$2\"/" "$file"
                else
                    sed -i '' "/^updated:/i\\
chunk: \"$2\"" "$file"
                fi
                echo -e "Chunk → ${BOLD}$2${NC}"
                shift 2 ;;
            --pokemon)
                if grep -q '^pokemon:' "$file"; then
                    sed -i '' "s/^pokemon: .*/pokemon: \"$2\"/" "$file"
                else
                    sed -i '' "/^updated:/i\\
pokemon: \"$2\"" "$file"
                fi
                echo -e "Pokemon → ${BOLD}$2${NC}"
                shift 2 ;;
            *)
                shift ;;
        esac
    done

    sed -i '' "s/^updated: .*/updated: ${today}/" "$file"
    echo -e "${GREEN}Updated task ${id}${NC}"
}

cmd_validate() {
    local errors=0
    local total=0

    for f in "$TASKS_DIR"/[0-9][0-9][0-9].md; do
        [ -f "$f" ] || continue
        total=$((total + 1))
        if ! validate_file "$f"; then
            errors=$((errors + 1))
        fi
    done

    echo ""
    if [ $errors -eq 0 ]; then
        echo -e "${GREEN}All ${total} task(s) valid${NC}"
    else
        echo -e "${RED}${errors}/${total} task(s) have errors${NC}"
        exit 1
    fi
}

cmd_summary() {
    local todo=0 inprog=0 done_count=0 blocked=0

    for f in "$TASKS_DIR"/[0-9][0-9][0-9].md; do
        [ -f "$f" ] || continue
        local status
        status=$(read_field "$f" "status")
        case "$status" in
            todo)        todo=$((todo + 1)) ;;
            in-progress) inprog=$((inprog + 1)) ;;
            done)        done_count=$((done_count + 1)) ;;
            blocked)     blocked=$((blocked + 1)) ;;
        esac
    done

    local total=$((todo + inprog + done_count + blocked))
    echo -e "${BOLD}Task Summary${NC}"
    echo "───────────────────"
    echo -e "  ${YELLOW}Todo:${NC}        $todo"
    echo -e "  ${BLUE}In Progress:${NC} $inprog"
    echo -e "  ${GREEN}Done:${NC}        $done_count"
    echo -e "  ${RED}Blocked:${NC}     $blocked"
    echo "───────────────────"
    echo -e "  ${BOLD}Total:${NC}       $total"
}

# --- Main ---

usage() {
    echo -e "${BOLD}task${NC} - Pokemon Emerald Rebalanced task manager"
    echo ""
    echo -e "${BOLD}Usage:${NC}"
    echo "  task list [--status STATUS] [--type TYPE] [--chunk CHUNK] [--pokemon NAME]"
    echo "  task get ID"
    echo "  task create --name NAME --description DESC [--type TYPE] [--priority PRI] [--pokemon NAME] [--chunk CHUNK] [--tags \"tag1,tag2\"]"
    echo "  task update ID --status STATUS [--priority PRI] [--chunk CHUNK] [--pokemon NAME]"
    echo "  task validate"
    echo "  task summary"
    echo ""
    echo -e "${BOLD}Status:${NC}   todo, in-progress, done, blocked"
    echo -e "${BOLD}Type:${NC}     pokemon, route, trainer, item, mechanic, chunk"
    echo -e "${BOLD}Priority:${NC} high, medium, low"
}

case "${1:-}" in
    list)     shift; cmd_list "$@" ;;
    get)      shift; cmd_get "$@" ;;
    create)   shift; cmd_create "$@" ;;
    update)   shift; cmd_update "$@" ;;
    validate) cmd_validate ;;
    summary)  cmd_summary ;;
    help|"")  usage ;;
    *)        echo -e "${RED}Unknown command: $1${NC}"; usage; exit 1 ;;
esac
